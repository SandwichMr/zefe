<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true"
    tools:context=".ThirdActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/third"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="620dp"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/txtThirdTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="INTENTS IMPLÍCITOS"
            android:textAlignment="center"
            android:textColor="@color/palette_deep_green"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/editTextPhone"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="12dp"
            android:autofillHints="phone"
            android:background="@drawable/edit_text_background"
            android:hint="Número telefónico"
            android:inputType="phone"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:textCursorDrawable="@null"
            android:textSize="16sp"
            app:layout_constraintEnd_toStartOf="@+id/imageButtonPhone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txtThirdTitle" />

        <ImageButton
            android:id="@+id/imageButtonPhone"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/icon_button_background"
            android:contentDescription="Marcar teléfono"
            android:padding="12dp"
            android:src="@android:drawable/sym_action_call"
            app:layout_constraintBottom_toBottomOf="@+id/editTextPhone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/editTextPhone"
            app:tint="@color/palette_deep_green" />

        <EditText
            android:id="@+id/editTextWeb"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="12dp"
            android:autofillHints="url"
            android:background="@drawable/edit_text_background"
            android:hint="www.ejemplo.com"
            android:inputType="textUri"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:textCursorDrawable="@null"
            android:textSize="16sp"
            app:layout_constraintEnd_toStartOf="@+id/imageButtonWeb"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editTextPhone" />

        <ImageButton
            android:id="@+id/imageButtonWeb"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/icon_button_background"
            android:contentDescription="Abrir página web"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_search"
            app:layout_constraintBottom_toBottomOf="@+id/editTextWeb"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/editTextWeb"
            app:tint="@color/palette_deep_green" />

        <Button
            android:id="@+id/buttonEmailMe"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/palette_sage"
            android:drawableStart="@android:drawable/ic_dialog_email"
            android:drawablePadding="10dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="Escríbeme"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:layout_constraintEnd_toStartOf="@+id/buttonContactPhone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editTextWeb" />

        <Button
            android:id="@+id/buttonContactPhone"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/palette_mint"
            android:drawableStart="@android:drawable/ic_menu_call"
            android:drawablePadding="10dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="Contáctame"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/buttonEmailMe"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/buttonEmailMe"
            app:layout_constraintTop_toTopOf="@+id/buttonEmailMe" />

        <ImageButton
            android:id="@+id/imageButtonCamera"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/panel_background"
            android:contentDescription="Abrir cámara"
            android:padding="24dp"
            android:src="@android:drawable/ic_menu_camera"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/buttonEmailMe"
            app:tint="@color/palette_deep_green" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
